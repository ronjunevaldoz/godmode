{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 skills/godmode-runtime/scripts/health_check.py 2>/dev/null || true",
            "statusMessage": "Godmode health check..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | grep -qE '(model_registry\\.yaml|intent_map\\.json)' && python3 skills/godmode-runtime/scripts/validate_registry.py || true",
            "statusMessage": "Validating registry..."
          }
        ]
      }
    ]
  }
}
